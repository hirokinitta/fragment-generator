{
  "name": "fragment-generator",
  "version": "0.1.0",
  "description": "記憶断片生成器",
  "author": "yourname",
  "main": "app/main.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development electron .",
    "build": "electron-builder --win --x64",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "com.yourname.fragment-generator",
    "productName": "Fragment Generator",
    "directories": {
      "output": "dist"
    },
    "files": [
      "app/**/*",
      "frontend/out/**/*"
    ],
    "extraResources": [
      {
        "from": "backend.exe",
        "to": "backend.exe"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "language": "1041",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Fragment Generator"
    }
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5"
  }
}
